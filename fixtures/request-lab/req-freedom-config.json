{
  "schemaVersion": 2,
  "exportedAt": "2026-07-21T00:00:00.000Z",
  "enabled": true,
  "groups": [
    {
      "id": "grp-page-patch",
      "name": "01 页面补丁（Mock / 限速 / 改请求体）",
      "enabled": true,
      "updatedAt": "2026-07-21T00:00:00.000Z",
      "rules": [
        {
          "id": "rule-mock-users",
          "name": "GET /api/users.json 返回 Mock",
          "enabled": true,
          "channel": "page-patch",
          "methods": ["GET"],
          "matchType": "contains",
          "pattern": "/api/users.json",
          "actions": [{
            "type": "mock-response",
            "mode": "static",
            "statusCode": 503,
            "responseHeaders": { "X-Mocked-By": "req-freedom" },
            "body": "{\"code\":503,\"message\":\"mocked\"}"
          }]
        },
        {
          "id": "rule-body-dynamic-echo",
          "name": "POST /api/echo 动态生成请求体",
          "enabled": true,
          "channel": "page-patch",
          "methods": ["POST"],
          "matchType": "contains",
          "pattern": "/api/echo",
          "actions": [{
            "type": "modify-request-body",
            "sourceMode": "dynamic",
            "mode": "merge-json",
            "content": "",
            "functionCode": "function modify(req) { return { ...req.json, variables: { ...req.json?.variables, first: 100, dynamic: true } }; }"
          }]
        },
        {
          "id": "rule-mock-echo-dynamic",
          "name": "POST /api/mock-echo 动态 Mock",
          "enabled": false,
          "channel": "page-patch",
          "methods": ["POST"],
          "matchType": "contains",
          "pattern": "/api/mock-echo",
          "actions": [{
            "type": "mock-response",
            "mode": "dynamic",
            "statusCode": 200,
            "body": "",
            "functionCode": "function mock(req) { return { source: 'dynamic-mock', method: req.method, body: req.json ?? req.body }; }"
          }]
        },
        {
          "id": "rule-graphql-getuser-mock",
          "name": "POST /api/graphql 仅 Mock GetUser 操作",
          "enabled": true,
          "channel": "page-patch",
          "methods": ["POST"],
          "matchType": "contains",
          "pattern": "/api/graphql",
          "bodyMatch": { "type": "graphql-operation", "value": "GetUser" },
          "actions": [{
            "type": "mock-response",
            "mode": "static",
            "statusCode": 200,
            "responseHeaders": { "X-Mocked-By": "req-freedom" },
            "body": "{\"data\":{\"user\":{\"id\":99,\"name\":\"Mock 用户\",\"role\":\"mocked\"}},\"receivedOperationName\":\"GetUser\",\"mocked\":true}"
          }]
        },
        {
          "id": "rule-slow-response",
          "name": "GET 大响应走 Slow 3G",
          "enabled": true,
          "channel": "page-patch",
          "methods": ["GET"],
          "matchType": "contains",
          "pattern": "/api/slow-response.txt",
          "actions": [{ "type": "delay", "throttlePreset": "slow-3g", "latencyMs": 400, "downloadKbps": 400, "uploadKbps": 400 }]
        }
      ]
    },
    {
      "id": "grp-dnr",
      "name": "02 DNR 网络规则",
      "enabled": true,
      "updatedAt": "2026-07-21T00:00:00.000Z",
      "rules": [
        {
          "id": "rule-redirect-source",
          "name": "GET redirect-source → redirect-target",
          "enabled": true,
          "channel": "dnr",
          "methods": ["GET"],
          "matchType": "contains",
          "pattern": "/api/redirect-source.json",
          "actions": [{ "type": "redirect", "redirectUrl": "http://127.0.0.1:4317/api/redirect-target.json" }]
        },
        {
          "id": "rule-params-and-headers",
          "name": "GET /api/params 注入参数和 Header",
          "enabled": true,
          "channel": "dnr",
          "methods": ["GET"],
          "matchType": "contains",
          "pattern": "/api/params.json",
          "actions": [
            { "type": "inject-params", "params": { "debug": "1", "environment": "local" } },
            { "type": "modify-headers", "headers": [{ "target": "request", "operation": "set", "header": "X-Req-Freedom", "value": "enabled" }] }
          ]
        },
        {
          "id": "rule-block-delete",
          "name": "DELETE /api/methods 直接拦截",
          "enabled": false,
          "channel": "dnr",
          "methods": ["DELETE"],
          "matchType": "contains",
          "pattern": "/api/methods",
          "actions": [{ "type": "block" }]
        }
      ]
    },
    {
      "id": "grp-page-script",
      "name": "03 页面脚本注入",
      "enabled": false,
      "updatedAt": "2026-07-21T00:00:00.000Z",
      "rules": [{
        "id": "rule-insert-script",
        "name": "加载完成后注入调试标记",
        "enabled": true,
        "channel": "page-patch",
        "methods": ["GET"],
        "matchType": "contains",
        "pattern": "127.0.0.1:4317",
        "actions": [{ "type": "insert-script", "codeType": "js", "timing": "document_end", "code": "document.documentElement.dataset.reqFreedom = 'enabled';" }]
      }]
    }
  ]
}
